PORT=5000
NODE_ENV=production
FRONTEND_URL=https://trustshield.vercel.app

# Database (required)
MONGODB_URI=your_mongodb_atlas_uri_here

# Auth (required)
JWT_SECRET=your_jwt_secret_min_64_chars_here

# AI Providers (optional - at least one recommended)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPEN_ROUTER_API_KEY=

# Cloudinary (optional - needed for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# External Security APIs (optional)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
GOOGLE_SAFE_BROWSING_API_KEY=
WHOIS_API_KEY=

# Rate Limiting (optional - for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
